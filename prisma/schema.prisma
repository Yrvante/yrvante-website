generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model CsvLead {
  id          String    @id @default(cuid())
  naam        String
  categorie   String?
  plaats      String?
  telefoon    String?
  website     String?
  email       String?
  rating      String?
  reviews     String?
  status      String    @default("nieuw")
  notitie     String?
  emailStatus String    @default("niet_verstuurd")
  emailSentAt DateTime?
  whatsappBeschikbaar String? @default("onbekend")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model EmailDailyLog {
  id    String @id @default(cuid())
  date  String @unique
  count Int    @default(0)
  dailyLimit Int @default(30)
}

model WhatsAppDailyLog {
  id         String @id @default(cuid())
  date       String @unique
  count      Int    @default(0)
  dailyLimit Int    @default(30)
}
