generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model CsvLead {
  id        String   @id @default(cuid())
  naam      String
  categorie String?
  plaats    String?
  telefoon  String?
  website   String?
  rating    String?
  reviews   String?
  status    String   @default("nieuw")
  notitie   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
